@prefix : <http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/faculty_ontology> .

<http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/faculty_ontology> rdf:type owl:Ontology .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#containCourses
:containCourses rdf:type owl:ObjectProperty ,
                         owl:AsymmetricProperty ;
                rdfs:domain [ rdf:type owl:Restriction ;
                              owl:onProperty :containCourses ;
                              owl:someValuesFrom :Program
                            ] ;
                rdfs:range [ rdf:type owl:Restriction ;
                             owl:onProperty :containCourses ;
                             owl:someValuesFrom :Course
                           ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasAdvisor
:hasAdvisor rdf:type owl:ObjectProperty ;
            owl:inverseOf :isAdvisorOf ;
            rdfs:domain [ rdf:type owl:Restriction ;
                          owl:onProperty :hasAdvisor ;
                          owl:someValuesFrom :PostgraduateStudent
                        ] ;
            rdfs:range [ rdf:type owl:Restriction ;
                         owl:onProperty :hasAdvisor ;
                         owl:someValuesFrom :AcademicStaff
                       ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasEnrolledStudents
:hasEnrolledStudents rdf:type owl:ObjectProperty ,
                              owl:AsymmetricProperty ;
                     rdfs:domain [ rdf:type owl:Restriction ;
                                   owl:onProperty :hasEnrolledStudents ;
                                   owl:someValuesFrom :Program
                                 ] ;
                     rdfs:range [ rdf:type owl:Restriction ;
                                  owl:onProperty :hasEnrolledStudents ;
                                  owl:someValuesFrom :Student
                                ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasMember
:hasMember rdf:type owl:ObjectProperty ;
           owl:inverseOf :isMemberOf ;
           rdf:type owl:AsymmetricProperty ;
           rdfs:domain [ rdf:type owl:Restriction ;
                         owl:onProperty :hasMember ;
                         owl:someValuesFrom :Department
                       ] ;
           rdfs:range [ rdf:type owl:Restriction ;
                        owl:onProperty :hasMember ;
                        owl:someValuesFrom :Person
                      ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#isAdvisorOf
:isAdvisorOf rdf:type owl:ObjectProperty ;
             rdfs:domain [ rdf:type owl:Restriction ;
                           owl:onProperty :isAdvisorOf ;
                           owl:someValuesFrom :AcademicStaff
                         ] ;
             rdfs:range [ rdf:type owl:Restriction ;
                          owl:onProperty :isAdvisorOf ;
                          owl:someValuesFrom :Student
                        ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#isCourseOf
:isCourseOf rdf:type owl:ObjectProperty ;
            owl:inverseOf :offersCourse ;
            rdf:type owl:AsymmetricProperty ;
            rdfs:domain [ rdf:type owl:Restriction ;
                          owl:onProperty :isCourseOf ;
                          owl:someValuesFrom :Course
                        ] ;
            rdfs:range [ rdf:type owl:Restriction ;
                         owl:onProperty :isCourseOf ;
                         owl:someValuesFrom :Department
                       ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#isMemberOf
:isMemberOf rdf:type owl:ObjectProperty ,
                     owl:AsymmetricProperty ;
            rdfs:domain [ rdf:type owl:Restriction ;
                          owl:onProperty :isMemberOf ;
                          owl:someValuesFrom :Person
                        ] ;
            rdfs:range [ rdf:type owl:Restriction ;
                         owl:onProperty :isMemberOf ;
                         owl:someValuesFrom :Department
                       ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#isOfferedBy
:isOfferedBy rdf:type owl:ObjectProperty ;
             owl:inverseOf :offersProgram ;
             rdf:type owl:AsymmetricProperty ;
             rdfs:domain [ rdf:type owl:Restriction ;
                           owl:onProperty :isOfferedBy ;
                           owl:someValuesFrom :Program
                         ] ;
             rdfs:range [ rdf:type owl:Restriction ;
                          owl:onProperty :isOfferedBy ;
                          owl:someValuesFrom :Department
                        ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#offersCourse
:offersCourse rdf:type owl:ObjectProperty ,
                       owl:AsymmetricProperty ;
              rdfs:domain [ rdf:type owl:Restriction ;
                            owl:onProperty :offersCourse ;
                            owl:someValuesFrom :Department
                          ] ;
              rdfs:range [ rdf:type owl:Restriction ;
                           owl:onProperty :offersCourse ;
                           owl:someValuesFrom :Course
                         ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#offersProgram
:offersProgram rdf:type owl:ObjectProperty ,
                        owl:AsymmetricProperty ;
               rdfs:domain [ rdf:type owl:Restriction ;
                             owl:onProperty :offersProgram ;
                             owl:someValuesFrom :Department
                           ] ;
               rdfs:range [ rdf:type owl:Restriction ;
                            owl:onProperty :offersProgram ;
                            owl:someValuesFrom :Program
                          ] .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#teaches
:teaches rdf:type owl:ObjectProperty ,
                  owl:AsymmetricProperty ;
         rdfs:domain [ rdf:type owl:Restriction ;
                       owl:onProperty :teaches ;
                       owl:someValuesFrom :AcademicStaff
                     ] ;
         rdfs:range [ rdf:type owl:Restriction ;
                      owl:onProperty :teaches ;
                      owl:someValuesFrom :Course
                    ] .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasCourseCode
:hasCourseCode rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Course ;
               rdfs:range xsd:string .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasCourseName
:hasCourseName rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Course ;
               rdfs:range xsd:string .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasCourseType
:hasCourseType rdf:type owl:DatatypeProperty ;
               rdfs:domain :Course ;
               rdfs:range xsd:string .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasEmail
:hasEmail rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty ;
          rdfs:domain :Person ;
          rdfs:range xsd:string .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasGrade
:hasGrade rdf:type owl:DatatypeProperty ,
                   owl:FunctionalProperty .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasLabHours
:hasLabHours rdf:type owl:DatatypeProperty ;
             rdfs:domain :Course ;
             rdfs:range xsd:integer .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasLectureHours
:hasLectureHours rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Course ;
                 rdfs:range xsd:integer .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasNumberOfCredits
:hasNumberOfCredits rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Course ;
                    rdfs:range xsd:double .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasPersonName
:hasPersonName rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Person ;
               rdfs:range xsd:string .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasPosition
:hasPosition rdf:type owl:DatatypeProperty ;
             rdfs:domain :AcademicStaff ;
             rdfs:range xsd:string .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasProgramDuration
:hasProgramDuration rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Program ;
                    rdfs:range xsd:integer .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasProgramName
:hasProgramName rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Program ;
                rdfs:range xsd:string .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#hasRegistrationNumber
:hasRegistrationNumber rdf:type owl:DatatypeProperty ,
                                owl:FunctionalProperty ;
                       rdfs:domain :Student ;
                       rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#AcademicStaff
:AcademicStaff rdf:type owl:Class ;
               rdfs:subClassOf :Person ;
               owl:disjointWith :Student .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#Course
:Course rdf:type owl:Class .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#Department
:Department rdf:type owl:Class ;
            owl:disjointWith :Person ,
                             :Program .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#Person
:Person rdf:type owl:Class ;
        owl:disjointWith :Program .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#PostgraduateProgram
:PostgraduateProgram rdf:type owl:Class ;
                     rdfs:subClassOf :Program ;
                     owl:disjointWith :UndergraduateProgram .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#PostgraduateStudent
:PostgraduateStudent rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( :Student
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty :hasEnrolledStudents ;
                                                                  owl:allValuesFrom :PostgraduateProgram
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf :Student ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty :hasAdvisor ;
                                       owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                       owl:onClass :AcademicStaff
                                     ] ;
                     owl:disjointWith :UndergraduateStudent .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#Program
:Program rdf:type owl:Class .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#Student
:Student rdf:type owl:Class ;
         rdfs:subClassOf :Person .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#UndergraduateProgram
:UndergraduateProgram rdf:type owl:Class ;
                      rdfs:subClassOf :Program .


###  http://www.semanticweb.org/hevindutilakasena/ontologies/2026/1/untitled-ontology-13#UndergraduateStudent
:UndergraduateStudent rdf:type owl:Class ;
                      owl:equivalentClass [ owl:intersectionOf ( :Student
                                                                 [ rdf:type owl:Restriction ;
                                                                   owl:onProperty :hasEnrolledStudents ;
                                                                   owl:allValuesFrom :UndergraduateProgram
                                                                 ]
                                                               ) ;
                                            rdf:type owl:Class
                                          ] ;
                      rdfs:subClassOf :Student ,
                                      [ rdf:type owl:Restriction ;
                                        owl:onProperty :hasAdvisor ;
                                        owl:maxCardinality "0"^^xsd:nonNegativeInteger
                                      ] .


